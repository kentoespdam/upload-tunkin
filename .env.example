# App
APP_NAME="Upload Tunkin App"
POOL_SIZE=2
MAX_POOL_SIZE=5

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=smartoffice
KPI_TABLE_NAME=salary_kpi

# JWT
JWT_SECRET_KEY=your_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_CLIENT_ID=upload-tunkin-client
JWT_CLIENT_SECRET=your_client_secret_here

# SQIDS
SQIDS_ALPHABET=
SQIDS_MIN_LENGTH=6

# CORS (Cross-Origin Resource Sharing)
# Comma-separated list of allowed origins. Use '*' for all origins.
CORS_ORIGINS=*
# Allowed HTTP methods. Use '*' for all methods.
CORS_METHODS=*
# Allowed request headers. Use '*' for all headers.
CORS_HEADERS=*
# Whether to allow cookies and authentication headers. Set to 'true' only if needed.
CORS_ALLOW_CREDENTIALS=false